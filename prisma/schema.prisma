// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
// Get a free hosted Postgres database in seconds: `npx create-db`
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}
datasource db {
  provider  = "postgresql"
  url       = env("SITE_DATABASE_URL")
  directUrl = env("SITE_DIRECT_URL")
}
model Event {
  id           String  @id @default(uuid())
  slug         String  @unique
  title        String
  description  String? @db.Text
  themeConfig  String  @default("{}") @db.Text
  featureFlags String  @default("{}") @db.Text
  labelConfig  String  @default("{}") @db.Text
  news              News[]
  schedules         Schedule[]
  rules             Rule[]
  tracks            Track[]
  trackHonbans      TrackHonban[]
  faqs              Faq[]
  userPlaylists     UserPlaylist[]
  userPlaylistSubs  UserPlaylistSub[]
  userIllPlaylists  UserIllustrationPlaylist[]
  awards            Award[]
  premiereSchedules PremiereSchedule[]
  votes             Vote[]
  trackThumbnails   TrackThumbnail[]
  voteResults       VoteResult[]
  voteDisclosures   VoteDisclosure[]
  adminUsers        AdminUser[]
  settings          Setting[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model News {
  id        Int      @id @default(autoincrement())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  title     String
  content   String?  @db.Text
  createdAt DateTime @default(now())
}
model Schedule {
  id      Int    @id @default(autoincrement())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  title   String
  date    String
  order   Int    @default(0)
}
model Rule {
  id      Int    @id @default(autoincrement())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  title   String @default("繧ｿ繧､繝医Ν")
  icon    String @default("笨ｨ")
  content String
  order   Int    @default(0)
}
model Track {
  id             Int      @id @default(autoincrement())
  eventId        String
  event          Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  timestamp      String   @unique
  xAccount       String?
  title          String
  songUrl        String
  audioUrl       String?
  lyrics         String?  @db.Text
  publishConsent String?
  artistName     String?
  email          String?
  agreedToTerms  String?
  analysis       String?  @db.Text
  review         String?  @db.Text
  genre          String?
  published      Boolean  @default(false)
  entryNo        String?  @db.Text
  password       String?
  musicFileUrl   String?  @db.Text
  srtFileUrl     String?  @db.Text
  createdAt      DateTime @default(now())
}
model TrackHonban {
  id             Int      @id @default(autoincrement())
  eventId        String
  event          Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  timestamp      String   @unique
  xAccount       String?
  title          String
  songUrl        String
  audioUrl       String?
  lyrics         String?  @db.Text
  publishConsent String?
  artistName     String?
  email          String?
  agreedToTerms  String?
  analysis       String?  @db.Text
  review         String?  @db.Text
  genre          String?
  published      Boolean  @default(false)
  entryNo        String?  @db.Text
  password       String?
  musicFileUrl   String?  @db.Text
  srtFileUrl     String?  @db.Text
  createdAt      DateTime @default(now())
  @@map("track_honban")
}
model Setting {
  id      Int    @id @default(autoincrement())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  key     String
  value   String
  @@unique([eventId, key])
}
model Faq {
  id       Int    @id @default(autoincrement())
  eventId  String
  event    Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  question String @db.Text
  answer   String @db.Text
  order    Int    @default(0)
}
model UserPlaylist {
  id            Int      @id @default(autoincrement())
  eventId       String
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userName      String   @unique
  xAccountId    String?
  appeal        String?  @db.Text
  trackIds      String   @db.Text
  trackEntryNos String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
model UserPlaylistSub {
  id            Int      @id @default(autoincrement())
  eventId       String
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userName      String
  xAccountId    String?
  appeal        String?  @db.Text
  trackIds      String   @db.Text
  trackEntryNos String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
model UserIllustrationPlaylist {
  id            Int      @id @default(autoincrement())
  eventId       String
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userName      String
  xAccountId    String?
  appeal        String?  @db.Text
  trackIds      String   @db.Text
  trackEntryNos String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
model Award {
  id          Int      @id @default(autoincrement())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  trackId     Int?
  entryNo     String?
  category    String // "AI_LYRIC", "CURATOR", "USER_CHOICE"
  rank        Int
  title       String
  note        String?  @db.Text
  description String?  @db.Text
  extraInfo   String? // 逾ｨ謨ｰ繧・女雉樒炊逕ｱ縺ｮ陬懆ｶｳ縺ｪ縺ｩ
  isPublished Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
model PremiereSchedule {
  id               Int      @id @default(autoincrement())
  eventId          String
  event            Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  day              Int
  date             DateTime
  youtubeUrl       String?  @db.Text
  trackRange       String
  trackCount       Int
  remarks          String?
  isPublic         Boolean  @default(true)
  acceptsThumbnail Boolean  @default(false) // サムネイル募集を受け付けるかどうか
  thumbnailDriveId String?  @db.Text // プレミアサムネイルのGoogleドライブID
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([eventId, day])
}
model Vote {
  id            Int      @id @default(autoincrement())
  eventId       String
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  responseId    String? // 1蝗槭・蝗樒ｭ斐ｒ隴伜挨縺吶ｋID
  timestamp     String? // 繝輔か繝ｼ繝縺ｮ繧ｿ繧､繝繧ｹ繧ｿ繝ｳ繝・  voterName     String? // 謚慕･ｨ閠・錐
  targetContent String? // 謚慕･ｨ縺輔ｌ縺滓峇蜷阪ｄ逡ｪ蜿ｷ
  createdAt     DateTime @default(now())
}
model TrackThumbnail {
  id           Int       @id @default(autoincrement())
  eventId      String
  event        Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  trackId      Int       @unique // 1讌ｽ譖ｲ1譫壹・蛻ｶ蠕｡
  entryNo      String?   @db.Text // 邂｡逅・・辣ｧ蜷育畑
  trackTitle   String?   @db.Text // 邂｡逅・・辣ｧ蜷育畑
  artistName   String?
  twitterId    String?
  isAnonymous  Boolean   @default(false) // 邨ｵ蟶ｫ蜷阪・蛹ｿ蜷榊ｸ梧悍繝輔Λ繧ｰ
  isXAnonymous Boolean   @default(false) // X ID縺ｮ蛹ｿ蜷榊ｸ梧悍繝輔Λ繧ｰ
  status       String    @default("LOCK") // LOCK, PENDING, APPROVED, REJECTED
  driveFileId  String?
  lockedAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
model VoteResult {
  id         Int      @id @default(autoincrement())
  eventId    String
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  trackId    Int      @unique
  entryNo    String?
  xAccount   String?
  artistName String?
  title      String
  totalVotes Int      @default(0)
  selfVotes  Int      @default(0)
  rank       Int      @default(211)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
model VoteDisclosure {
  id              Int      @id @default(autoincrement())
  eventId         String
  event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  timestamp       String?
  email           String?
  xAccount        String?
  entryNo         String?
  wantsDisclosure Boolean  @default(false)
  password        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
model AdminUser {
  id        String   @id @default(uuid())
  eventId   String?
  event     Event?   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  email     String   @unique
  password  String   // Hashed password
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EventTemplate {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  description  String?  @db.Text
  themeConfig  String   @default("{}") @db.Text
  featureFlags String   @default("{}") @db.Text
  labelConfig  String   @default("{}") @db.Text
  settingsData String   @default("[]") @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model GlobalSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}
